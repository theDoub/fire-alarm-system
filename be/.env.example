# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/fire_alarm_db

# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# JWT Configuration
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=noreply@firealarm.com
EMAIL_PASSWORD=

# Alert Configuration
ALERT_THRESHOLD_TEMP=60
ALERT_THRESHOLD_SMOKE=500

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
