DB_NAME=firealert
DB_USER=firealert_user
DB_PASSWORD=secure_password_123
DB_PORT=5432

SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/firealert
SPRING_DATASOURCE_USERNAME=firealert_user
SPRING_DATASOURCE_PASSWORD=secure_password_123
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_FIREALERT_BACKEND=DEBUG
LOGGING_FILE_NAME=logs/application.log
